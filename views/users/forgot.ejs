<% layout("layouts/boilerplate") %>

<section class="auth-layout">
    <div class="auth-copy">
        <p class="eyebrow">Password Recovery</p>
        <h1>Get an OTP on your email.</h1>
        <p>
            Enter the email connected to your ReelVault account and use the OTP to set a new password.
        </p>
    </div>

    <form action="/forgot-password" method="POST" class="auth-panel">
        <h2>Forgot Password</h2>

        <div class="mb-4">
            <label class="form-label" for="email">Account Email</label>
            <input
                id="email"
                type="email"
                name="email"
                class="form-control"
                autocomplete="email"
                required
            >
        </div>

        <button type="submit" class="btn btn-accent w-100">
            <i class="fa-solid fa-envelope-circle-check"></i>
            Send OTP
        </button>

        <p class="auth-switch">
            Remembered it?
            <a href="/login">Login</a>
        </p>
    </form>
</section>
